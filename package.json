{
  "name": "coursera-scraper",
  "version": "1.0.1",
  "description": "Unofficial Coursera scraper/downloader CLI for Node.js.",
  "main": "dist/batch-down.js",
  "exports": {
    ".": "./dist/batch-down.js"
  },
  "bin": {
    "coursera-dl": "bin/coursera-dl.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "lint": "eslint \"src/**/*.ts\"",
    "audit:prod": "npm audit --omit=dev",
    "scan:sensitive": "node scripts/scan-sensitive.js",
    "prepack": "npm run build",
    "prepublishOnly": "npm run scan:sensitive && npm run lint",
    "start": "tsx src/index.ts",
    "auth": "tsx src/auth.ts",
    "download": "tsx src/download.ts",
    "cli": "tsx src/cli.ts"
  },
  "keywords": [
    "coursera",
    "scraper",
    "downloader",
    "nodejs",
    "cli",
    "typescript"
  ],
  "author": "delusionofgrandeur",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/delusionofgrandeur/coursera-scraper.git"
  },
  "bugs": {
    "url": "https://github.com/delusionofgrandeur/coursera-scraper/issues"
  },
  "homepage": "https://github.com/delusionofgrandeur/coursera-scraper#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.2",
    "chalk": "^5.6.2",
    "cli-progress": "^3.12.0",
    "p-limit": "^3.1.0",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "type": "module"
}
